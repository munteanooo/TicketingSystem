@page "/register"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Register</h3>

<div>
    <div style="margin-bottom: 15px;">
        <label>Full Name:</label>
        <input type="text" @bind="fullName" @bind:event="oninput"
               style="width: 300px; padding: 5px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label>Email:</label>
        <input type="email" @bind="email" @bind:event="oninput"
               style="width: 300px; padding: 5px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label>Password:</label>
        <input type="password" @bind="password" @bind:event="oninput"
               style="width: 300px; padding: 5px;" />
    </div>

    <button @onclick="HandleRegister" style="padding: 10px 20px;">
        Register
    </button>

    @if (!string.IsNullOrEmpty(message))
    {
        <div style="margin-top: 15px; color: @(isError ? "red" : "green")">
            @message
        </div>
    }

    <div style="margin-top: 20px;">
        <a href="/login">Already have an account? Login</a>
    </div>
</div>

@code {
    private string fullName = "";
    private string email = "";
    private string password = "";
    private string message = "";
    private bool isError = false;

    private async Task HandleRegister()
    {
        try
        {
            var registerData = new
            {
                fullName = fullName,
                email = email,
                password = password
            };

            var response = await Http.PostAsJsonAsync("api/auth/register", registerData);

            if (response.IsSuccessStatusCode)
            {
                message = "Registration successful! Redirecting to login...";
                isError = false;

                await Task.Delay(2000);
                Navigation.NavigateTo("/login", true);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                message = $"Registration failed: {errorContent}";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"Connection error: {ex.Message}";
            isError = true;
        }
    }
}