@page "/tickets"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>My Tickets</h3>

<div style="margin-bottom: 20px;">
    <button @onclick="LoadTickets" style="padding: 10px 20px; margin-right: 10px;">
        Refresh
    </button>
    <button @onclick="GoToCreateTicket" style="padding: 10px 20px;">
        Create New Ticket
    </button>
</div>

@if (isLoading)
{
    <p>Loading tickets...</p>
}
else if (tickets == null || tickets.Count == 0)
{
    <div style="border: 1px solid #ccc; padding: 40px; text-align: center; border-radius: 5px;">
        <p>No tickets found</p>
        <button @onclick="GoToCreateTicket" style="padding: 10px 20px; margin-top: 10px;">
            Create Your First Ticket
        </button>
    </div>
}
else
{
    <div style="border: 1px solid #ccc; border-radius: 5px;">
        <h4 style="padding: 15px; background-color: #f5f5f5; margin: 0;">
            Tickets (@tickets.Count)
        </h4>

        @foreach (var ticket in tickets)
        {
            <div style="padding: 15px; border-bottom: 1px solid #eee;">
                <div style="font-weight: bold; font-size: 1.1em;">
                    #@ticket.id - @ticket.title
                </div>
                <div style="margin-top: 5px; color: #666;">
                    Status:
                    <span style="color: @GetStatusColor(ticket.status)">
                        @ticket.status
                    </span>
                </div>
                <button @onclick="() => ViewTicket(ticket.id)"
                        style="margin-top: 10px; padding: 5px 10px; font-size: 0.9em;">
                    View Details
                </button>
            </div>
        }
    </div>
}

@code {
    private List<Ticket> tickets = new();
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task LoadTickets()
    {
        isLoading = true;

        try
        {
            tickets = await Http.GetFromJsonAsync<List<Ticket>>("api/tickets")
                     ?? new List<Ticket>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tickets: {ex.Message}");
            tickets = new List<Ticket>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCreateTicket()
    {
        Navigation.NavigateTo("/create-ticket");
    }

    private void ViewTicket(int id)
    {
        Console.WriteLine($"Viewing ticket #{id}");
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Open" => "blue",
            "In Progress" => "orange",
            "Closed" => "gray",
            _ => "black"
        };
    }

    private class Ticket
    {
        public int id { get; set; }
        public string title { get; set; }
        public string status { get; set; }
    }
}