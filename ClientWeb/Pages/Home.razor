@page "/"

<h1>Welcome to Ticketing System</h1>

<div>
    <p>Manage your support tickets efficiently</p>

    <div style="margin: 30px 0;">
        <h3>Quick Actions:</h3>

        <div style="display: flex; gap: 20px; margin-top: 20px;">
            <div style="border: 1px solid #ccc; padding: 20px; border-radius: 5px;">
                <h4>Create Ticket</h4>
                <p>Report a new issue</p>
                <button @onclick="GoToCreateTicket" style="padding: 10px 20px;">
                    Create New
                </button>
            </div>

            <div style="border: 1px solid #ccc; padding: 20px; border-radius: 5px;">
                <h4>My Tickets</h4>
                <p>View all your tickets</p>
                <button @onclick="GoToTickets" style="padding: 10px 20px;">
                    View Tickets
                </button>
            </div>
        </div>
    </div>

    <div style="margin-top: 40px;">
        <h4>Status:</h4>
        <div style="border: 1px solid #ccc; padding: 15px; border-radius: 5px;">
            <p>API Connection: <span style="color: green;">✓ Connected</span></p>
            <p>Need to login to create tickets</p>
            <a href="/login">Click here to login</a>
        </div>
    </div>
</div>

@code {
    private void GoToCreateTicket()
    {
        Navigation.NavigateTo("/create-ticket");
    }

    private void GoToTickets()
    {
        Navigation.NavigateTo("/tickets");
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;
}