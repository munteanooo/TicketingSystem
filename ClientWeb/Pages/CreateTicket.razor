@page "/create-ticket"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Create New Ticket</h3>

<div>
    <div style="margin-bottom: 15px;">
        <label>Title:</label>
        <input type="text" @bind="title" @bind:event="oninput"
               style="width: 300px; padding: 5px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label>Description:</label><br />
        <textarea @bind="description" @bind:event="oninput"
                  rows="5" style="width: 100%; max-width: 500px; padding: 5px;"></textarea>
    </div>

    <div style="margin-top: 20px;">
        <button @onclick="SubmitTicket" style="padding: 10px 20px; margin-right: 10px;">
            Submit Ticket
        </button>
        <button @onclick="Cancel" style="padding: 10px 20px;">
            Cancel
        </button>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div style="margin-top: 15px; padding: 10px; background-color: @(isError ? "#ffebee" : "#e8f5e8");
                 color: @(isError ? "#c62828" : "#2e7d32"); border-radius: 5px;">
            @message
        </div>
    }
</div>

@code {
    private string title = "";
    private string description = "";
    private string message = "";
    private bool isError = false;

    private async Task SubmitTicket()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            message = "Title is required";
            isError = true;
            return;
        }

        try
        {
            var ticketData = new { title = title, description = description };
            var response = await Http.PostAsJsonAsync("api/tickets", ticketData);

            if (response.IsSuccessStatusCode)
            {
                message = "Ticket created successfully!";
                isError = false;

                // Clear form
                title = "";
                description = "";

                // Redirect to tickets list after 2 seconds
                await Task.Delay(2000);
                Navigation.NavigateTo("/tickets", true);
            }
            else
            {
                message = "Failed to create ticket";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            message = $"Connection error: {ex.Message}";
            isError = true;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/");
    }
}