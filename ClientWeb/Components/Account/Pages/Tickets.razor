@* @page "/tickets"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager NavigationManager
@using MudBlazor
@inject HttpClient Http
@using TicketingSystem.Application.DTOs

<AuthorizeView>
    <Authorized Context="authContext">
        <PageTitle>Tickets</PageTitle>

        <h2>Create a New Ticket</h2>

        <!-- Formularul pentru creare ticket -->
        <EditForm Model="@newTicket" OnValidSubmit="OnCreateTicket" FormName="CreateTicketForm" Context="formContext">
            <DataAnnotationsValidator />
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Title" @bind-Value="newTicket.Title" For="@(() => newTicket.Title)" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="12">
                    <MudTextField Label="Description" @bind-Value="newTicket.Description" For="@(() => newTicket.Description)" Lines="4" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Create Ticket</MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>

        <h3 class="mt-5">Your Tickets</h3>

        <!-- Tabel pentru ticketele existente -->
        <MudTable Items="@tickets" Hover="true" Striped="true" RowTemplateContext="ticketContext">
            <HeaderContent>
                <MudTh>Title</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Created At</MudTh>
            </HeaderContent>
            <RowTemplate Context="ticketContext">
                <MudTd>@ticketContext.Title</MudTd>
                <MudTd>@ticketContext.Description</MudTd>
                <MudTd>@ticketContext.Status</MudTd>
                <MudTd>@ticketContext.CreatedAt.ToString("g")</MudTd>
            </RowTemplate>
        </MudTable>
    </Authorized>
    <NotAuthorized>
        <MudText Color="Color.Error">You must be logged in to view tickets.</MudText>
    </NotAuthorized>
</AuthorizeView>

@code {
    private CreateTicketDto newTicket = new();
    private List<TicketDto> tickets = new();

    protected override async Task OnInitializedAsync()
    {
        tickets = await Http.GetFromJsonAsync<List<TicketDto>>("api/tickets/all");
    }

    private async Task OnCreateTicket()
    {
        try
        {
            // Trimite DTO-ul către API
            var response = await Http.PostAsJsonAsync("api/tickets", new CreateTicketDto
            {
                Title = newTicket.Title,
                Description = newTicket.Description,
                Category = newTicket.Category,
                Priority = newTicket.Priority
            });

            if (response.IsSuccessStatusCode)
            {
                // Deserializare răspuns
                var createdTicket = await response.Content.ReadFromJsonAsync<TicketDto>();
                if (createdTicket != null)
                {
                    tickets.Add(createdTicket);
                    newTicket = new CreateTicketDto(); 
                }
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error creating ticket: {response.StatusCode}, {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }
} *@
