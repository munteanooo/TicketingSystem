@page "/ticket/list"
@attribute [Authorize]
@inject ITicketService TicketService
@using ClientWeb.Models
@using ClientWeb.Services
@using ClientWeb.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<div class="container-fluid mt-5">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">📋 Tichete Mele</h3>
                    <a href="/ticket/create" class="btn btn-light btn-sm">➕ Tichet Nou</a>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Se încarcă...</span>
                            </div>
                            <p class="mt-2">Se încarcă tichete...</p>
                        </div>
                    }
                    else if (tickets == null || tickets.Count == 0)
                    {
                        <div class="alert alert-info mt-3">
                            <strong>Niciun tichet</strong> - Nu ai niciun tichet. <a href="/ticket/create">Crează-l acum</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Titlu</th>
                                        <th>Descriere</th>
                                        <th>Status</th>
                                        <th>Prioritate</th>
                                        <th>Data</th>
                                        <th>Acțiuni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ticket in tickets)
                                    {
                                        <tr>
                                            <td><small>#@ticket.Id</small></td>
                                            <td><strong>@ticket.Title</strong></td>
                                            <td>
                                                @if (ticket.Description.Length > 50)
                                                {
                                                    <span>@ticket.Description.Substring(0, 50)...</span>
                                                }
                                                else
                                                {
                                                    <span>@ticket.Description</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (ticket.Status)
                                                {
                                                    case "Open":
                                                        <span class="badge bg-info">📖 Deschis</span>
                                                        break;
                                                    case "In Progress":
                                                        <span class="badge bg-warning">⚙️ În Progres</span>
                                                        break;
                                                    case "Closed":
                                                        <span class="badge bg-success">✓ Închis</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@ticket.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @switch (ticket.Priority)
                                                {
                                                    case "High":
                                                        <span class="badge bg-danger">🔴 Urgent</span>
                                                        break;
                                                    case "Normal":
                                                        <span class="badge bg-warning">🟡 Normal</span>
                                                        break;
                                                    case "Low":
                                                        <span class="badge bg-success">🟢 Scăzut</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@ticket.Priority</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <a href="/ticket/detail/@ticket.Id" class="btn btn-sm btn-info">👁️ Detalii</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TicketDto>? tickets;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task LoadTickets()
    {
        isLoading = true;
        tickets = await TicketService.GetMyTicketsAsync();
        isLoading = false;
    }
}