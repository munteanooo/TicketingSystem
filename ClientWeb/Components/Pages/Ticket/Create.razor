@page "/ticket/create"
@attribute [Authorize]
@inject ITicketService TicketService
@inject NavigationManager Nav
@using ClientWeb.Models
@using ClientWeb.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">➕ Crează un Tichet Nou</h3>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Eroare!</strong> @errorMessage
                            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                        </div>
                    }

                    <form @onsubmit="HandleCreateTicket">
                        <div class="mb-3">
                            <label class="form-label">Titlu *</label>
                            <input type="text" class="form-control" @bind="title"
                                   placeholder="Descrie pe scurt problema..." required disabled="@isLoading" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descriere</label>
                            <textarea class="form-control" rows="5" @bind="description"
                                      placeholder="Detaliază problema sau cererea..." disabled="@isLoading"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Prioritate</label>
                            <select class="form-select" @bind="priority" disabled="@isLoading">
                                <option value="Low">🟢 Scăzut</option>
                                <option value="Normal">🟡 Normal</option>
                                <option value="High">🔴 Urgent</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success flex-grow-1" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Se salvează...</span>
                                }
                                else
                                {
                                    <span>✓ Crează Tichet</span>
                                }
                            </button>
                            <a href="/ticket/list" class="btn btn-secondary flex-grow-1">Anulează</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string title = "";
    private string description = "";
    private string priority = "Normal";
    private string errorMessage = "";
    private bool isLoading = false;

    private async Task HandleCreateTicket()
    {
        if (string.IsNullOrEmpty(title))
        {
            errorMessage = "Titlul este obligatoriu";
            return;
        }

        isLoading = true;
        errorMessage = "";

        var request = new CreateTicketRequest
        {
            Title = title,
            Description = description,
            Priority = priority
        };

        var success = await TicketService.CreateTicketAsync(request);

        if (success)
        {
            Nav.NavigateTo("/ticket/list");
        }
        else
        {
            errorMessage = "Eroare la crearea tichetului. Încearcă din nou.";
        }

        isLoading = false;
    }
}