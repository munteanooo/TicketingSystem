@page "/auth/register"
@using ClientWeb.Models
@using ClientWeb.Services.Interfaces
@using Microsoft.AspNetCore.Components.Web
@inject IAuthService AuthService
@inject NavigationManager Nav
@rendermode @(new InteractiveServerRenderMode())

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>📝 Înregistrare</h2>
            <p>Creează-ți un cont nou</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <EditForm Model="@registerModel"
                  OnValidSubmit="HandleRegister"
                  FormName="RegisterForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Prenume</label>
                <InputText class="form-control"
                           @bind-Value="registerModel.FirstName"
                           placeholder="Ion" />
            </div>

            <div class="mb-3">
                <label>Nume</label>
                <InputText class="form-control"
                           @bind-Value="registerModel.LastName"
                           placeholder="Popescu" />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <InputText type="email"
                           class="form-control"
                           @bind-Value="registerModel.Email"
                           placeholder="exemplu@email.com" />
            </div>

            <div class="mb-3">
                <label>Parolă</label>
                <InputText type="password"
                           class="form-control"
                           @bind-Value="registerModel.Password"
                           placeholder="••••••••" />
            </div>

            <div class="mb-3">
                <label>Confirmă Parolă</label>
                <InputText type="password"
                           class="form-control"
                           @bind-Value="registerModel.ConfirmPassword"
                           placeholder="••••••••" />
            </div>

            <button type="submit"
                    class="btn btn-success w-100"
                    disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Se procesează...</span>
                }
                else
                {
                    <span>Înregistrare</span>
                }
            </button>
        </EditForm>

        <div class="auth-footer">
            <p>Ai deja cont? <a href="/auth/login">Conectează-te</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        Console.WriteLine("HandleRegister CALLED"); // temporar

        isLoading = true;
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrEmpty(registerModel.FirstName) ||
            string.IsNullOrEmpty(registerModel.LastName) ||
            string.IsNullOrEmpty(registerModel.Email) ||
            string.IsNullOrEmpty(registerModel.Password) ||
            string.IsNullOrEmpty(registerModel.ConfirmPassword))
        {
            errorMessage = "Completează toate câmpurile";
            isLoading = false;
            return;
        }

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Parolele nu se potrivesc";
            isLoading = false;
            return;
        }

        if (registerModel.Password.Length < 6)
        {
            errorMessage = "Parola trebuie să aibă cel puțin 6 caractere";
            isLoading = false;
            return;
        }

        try
        {
            var success = await AuthService.RegisterAsync(registerModel);

            if (success)
            {
                successMessage = "Înregistrare reușită! Poți să te conectezi acum.";
                registerModel = new RegisterRequest();
            }
            else
            {
                errorMessage = "Înregistrare eșuată. Încearcă din nou.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"A apărut o eroare: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
