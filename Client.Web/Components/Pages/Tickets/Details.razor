    private string GetUserName(UserDto? user)
    {
        if (user == null)
            return "Unknown User";

        return !string.IsNullOrEmpty(user.FullName)
            ? user.FullName
            : user.Email;
    }

    private Color GetPriorityColor(string priority)
    {
        return priority switch
        {
            "Critical" => Color.Error,
            "High" => Color.Warning,
            "Medium" => Color.Info,
            "Low" => Color.Success,
            _ => Color.Default
        };
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Open" => Color.Info,
            "InProgress" => Color.Warning,
            "OnHold" => Color.Secondary,
            "Resolved" => Color.Success,
            "Closed" => Color.Default,
            _ => Color.Default
        };
    }
} *@