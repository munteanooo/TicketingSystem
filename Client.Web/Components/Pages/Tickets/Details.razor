@* @using Client.Web.Services
@using ClientApi.Models
@using MudBlazor
@using TicketingSystem.ClientApi.Models
@code {
    [Parameter]
    public int Id { get; set; }

    private TicketDetailDto? ticketDetail;

    protected override async Task OnInitializedAsync()
    {
        await LoadTicket();
    }

    private async Task LoadTicket()
    {
        try
        {
            ticketDetail = await TicketService.GetTicketAsync(Id);
