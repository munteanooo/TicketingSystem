@page "/tickets"
@page "/tickets/{UserId:int}"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>@PageTitle</h3>

@if (ShowCreateButton)
{
    <button class="btn btn-primary mb-3" @onclick="NavigateToCreate">
        Crează Ticket Nou
    </button>
}

@if (tickets == null)
{
    <p>@LoadingMessage</p>
}
else if (tickets.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titlu</th>
                <th>Prioritate</th>
                <th>Status</th>
                <th>Data</th>
                @if (ShowActions)
                {
                    <th>Acțiuni</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in tickets)
            {
                <tr>
                    <td>@ticket.Id</td>
                    <td>
                        <strong>@ticket.Title</strong>
                        @if (ShowDescription)
                        {
                            <div class="text-muted small">
                                @GetShortDescription(ticket.Description)
                            </div>
                        }
                    </td>
                    <td>
                        <span class="badge @GetPriorityClass(ticket.Priority)">
                            @ticket.Priority
                        </span>
                    </td>
                    <td>
                        <span class="badge @(ticket.IsResolved ? "bg-success" : "bg-warning")">
                            @(ticket.IsResolved ? "Rezolvat" : "Deschis")
                        </span>
                    </td>
                    <td>@ticket.Created.ToString("dd.MM.yyyy")</td>
                    @if (ShowActions)
                    {
                        <td>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewTicket(ticket.Id)">
                                Vezi
                            </button>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        @EmptyMessage
    </div>
}

@code {
    private List<Ticket> tickets = new();

    [Parameter]
    public int UserId { get; set; }

    [Parameter]
    public string PageTitle { get; set; } = "Ticketele Mele";

    [Parameter]
    public string LoadingMessage { get; set; } = "Se încarcă...";

    [Parameter]
    public string EmptyMessage { get; set; } = "Nu ai niciun ticket. Creează primul ticket!";

    [Parameter]
    public bool ShowCreateButton { get; set; } = true;

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public bool ShowDescription { get; set; } = false;

    [Parameter]
    public EventCallback<int> OnTicketSelected { get; set; }

    protected override async Task OnInitializedAsync()
    {
        tickets = new List<Ticket>
        {
            new Ticket { Id = 1, Title = "Problemă cu login", Description = "Nu mă pot conecta la contul meu", Priority = "Medium", IsResolved = false, Created = DateTime.Now },
            new Ticket { Id = 2, Title = "Cont blocat", Description = "Contul meu este blocat din cauza multiplelor încercări de login", Priority = "High", IsResolved = true, Created = DateTime.Now.AddDays(-1) }
        };

        if (UserId > 0)
        {
            tickets = await Http.GetFromJsonAsync<List<Ticket>>($"api/tickets/user/{UserId}") ?? new();
        }
        else
        {
            tickets = await Http.GetFromJsonAsync<List<Ticket>>("api/tickets") ?? new();
        }
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/create-ticket");
    }

    private async Task ViewTicket(int ticketId)
    {
        await OnTicketSelected.InvokeAsync(ticketId);
        Navigation.NavigateTo($"/ticket-details/{ticketId}");
    }

    private string GetPriorityClass(string priority)
    {
        return priority switch
        {
            "High" => "bg-danger",
            "Medium" => "bg-warning",
            "Low" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private string GetShortDescription(string description)
    {
        if (string.IsNullOrEmpty(description))
            return string.Empty;

        return description.Length > 50
            ? description.Substring(0, 50) + "..."
            : description;
    }

    public class Ticket
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Priority { get; set; } = "Medium";
        public bool IsResolved { get; set; }
        public DateTime Created { get; set; }
        public int Used { get; set; }
    }
}