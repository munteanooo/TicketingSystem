@page "/create-ticket"
@page "/create-ticket/{InitialPriority}"
@inject NavigationManager Navigation

<div class="create-ticket-form">
    <h3>@PageTitle</h3>

    <form>
        <div class="mb-3">
            <label class="form-label">@TitleLabel</label>
            <input @bind="newTicket.Title" class="form-control" placeholder="@TitlePlaceholder" />
        </div>

        <div class="mb-3">
            <label class="form-label">@DescriptionLabel</label>
            <textarea @bind="newTicket.Description" class="form-control" rows="4"
                      placeholder="@DescriptionPlaceholder"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">@PriorityLabel</label>
            <select @bind="newTicket.Priority" class="form-select">
                <option value="Low">@LowPriorityText</option>
                <option value="Medium">@MediumPriorityText</option>
                <option value="High">@HighPriorityText</option>
            </select>
        </div>

        <div class="button-group">
            <button type="button" class="btn btn-success" @onclick="NewTicket">
                @CreateButtonText
            </button>

            @if (ShowCancelButton)
            {
                <button type="button" class="btn btn-secondary" @onclick="Cancel">
                    @CancelButtonText
                </button>
            }
        </div>
    </form>
</div>

@code {
    private Ticket newTicket = new();

    [Parameter]
    public string InitialPriority { get; set; } = "Medium";

    [Parameter]
    public string PageTitle { get; set; } = "Crează Ticket Nou";

    [Parameter]
    public string TitleLabel { get; set; } = "Titlu";

    [Parameter]
    public string TitlePlaceholder { get; set; } = "Introdu titlul ticketului";

    [Parameter]
    public string DescriptionLabel { get; set; } = "Descriere";

    [Parameter]
    public string DescriptionPlaceholder { get; set; } = "Descrie problema în detaliu...";

    [Parameter]
    public string PriorityLabel { get; set; } = "Prioritate";

    [Parameter]
    public string LowPriorityText { get; set; } = "Low";

    [Parameter]
    public string MediumPriorityText { get; set; } = "Medium";

    [Parameter]
    public string HighPriorityText { get; set; } = "High";

    [Parameter]
    public string CreateButtonText { get; set; } = "Creează Ticket";

    [Parameter]
    public string CancelButtonText { get; set; } = "Anulează";

    [Parameter]
    public bool ShowCancelButton { get; set; } = true;

    [Parameter]
    public string SuccessUrl { get; set; } = "/tickets";

    [Parameter]
    public EventCallback<Ticket> OnTicketCreated { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(InitialPriority))
        {
            newTicket.Priority = InitialPriority;
        }
    }

    private async Task NewTicket()
    {
        if (!string.IsNullOrEmpty(newTicket.Title))
        {
            await OnTicketCreated.InvokeAsync(newTicket);
            Navigation.NavigateTo(SuccessUrl);
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/tickets");
    }

    public class Ticket
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Priority { get; set; } = "Medium";
    }
}