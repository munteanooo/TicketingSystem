<span class="badge @badgeClass">@Priority</span>

@code {
    [Parameter]
    public string Priority { get; set; } = string.Empty;

    private string badgeClass => Priority switch
    {
        "High" => "bg-danger",
        "Medium" => "bg-warning",
        "Low" => "bg-success",  
        _ => "bg-secondary"
    };
}