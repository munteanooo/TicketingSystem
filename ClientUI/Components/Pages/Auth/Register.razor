@page "/auth/register"
@page "/register"
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<div class="d-flex justify-content-center align-items-center min-vh-100 p-4 bg-light">
    <div class="card shadow p-5" style="max-width: 400px; width: 100%;">
        <div class="card-body text-center mb-4">
            <h2 class="mb-4">Creează cont</h2>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mb-4">@errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mb-4">@successMessage</div>
            }
        </div>

        <form class="needs-validation" novalidate>
            <div class="row g-3 mb-3">
                <div class="col-6">
                    <input id="firstName" type="text" class="form-control form-control-lg"
                           placeholder="Nume" required />
                </div>
                <div class="col-6">
                    <input id="lastName" type="text" class="form-control form-control-lg"
                           placeholder="Prenume" required />
                </div>
            </div>
            <div class="mb-3">
                <input id="email" type="email" class="form-control form-control-lg"
                       placeholder="Email" autocomplete="email" required />
            </div>
            <div class="mb-3">
                <input id="password" type="password" class="form-control form-control-lg"
                       placeholder="Parolă (min 4)" autocomplete="new-password" minlength="4" required />
            </div>
            <div class="mb-4">
                <input id="confirmPassword" type="password" class="form-control form-control-lg"
                       placeholder="Confirmă parolă" autocomplete="new-password" required />
            </div>
            <button type="button" onclick="doRegister()" class="btn btn-success btn-lg w-100 mb-3" id="registerBtn">
                Creează cont
            </button>
            <div class="text-center">
                <a href="/auth/login" class="text-decoration-none">Deja ai cont? Login</a>
            </div>
        </form>
    </div>
</div>

<script>
    let isLoading = false;

    function doRegister() {
        if (isLoading) return;

        const firstName = document.getElementById('firstName').value.trim();
        const lastName = document.getElementById('lastName').value.trim();
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        const btn = document.getElementById('registerBtn');

        // Validare
        if (!firstName || !lastName || !email || !password || !confirmPassword) {
            alert('Toate câmpurile sunt obligatorii');
            return;
        }
        if (password.length < 4) {
            alert('Parola minim 4 caractere');
            return;
        }
        if (password !== confirmPassword) {
            alert('Parolele nu se potrivesc');
            return;
        }

        isLoading = true;
        btn.disabled = true;
        btn.innerHTML = 'Se creează...';

        console.log('🟢 REGISTER:', firstName, email);

        fetch('http://localhost:5053/api/Auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                FirstName: firstName,
                LastName: lastName,
                Email: email,
                Password: password,
                ConfirmPassword: confirmPassword
            })
        })
        .then(res => res.ok ? res.json() : Promise.reject('Register eșuat'))
        .then(data => {
            console.log('✅ REGISTER OK!', data);
            if (data.success) {
                btn.innerHTML = 'Cont creat!';
                setTimeout(() => window.location.href = '/auth/login', 1500);
            } else {
                throw new Error(data.message || 'Eroare register');
            }
        })
        .catch(err => {
            console.error('❌ REGISTER ERROR:', err);
            alert(err.message || 'Eroare la înregistrare');
            btn.disabled = false;
            btn.innerHTML = 'Creează cont';
            isLoading = false;
        });
    }

    // Enter key
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('firstName').focus();
        document.addEventListener('keypress', e => {
            if (e.key === 'Enter' && !isLoading) doRegister();
        });
    });
</script>

@code {
    private string? errorMessage;
    private string? successMessage;
}
