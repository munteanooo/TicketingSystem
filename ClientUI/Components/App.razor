@using ClientUI.Components.Layout
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using ClientUI.Services
@using MudBlazor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ticketing System</title>
    <base href="/" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="css/app.css" />
</head>
<body>
    <MudThemeProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <CascadingAuthenticationState>
        <Router AppAssembly="@typeof(App).Assembly" OnNavigateAsync="@OnNavigateAsync">
            <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                    <NotAuthorized>
                        <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                            <div class="text-center">
                                <h2>Acces interzis</h2>
                                <p>Nu ești autorizat. Te rugăm să te autentifici.</p>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@RedirectToLogin" Class="mt-3">
                                    <i class="bi bi-box-arrow-in-right me-2"></i> Mergi la Login
                                </MudButton>
                            </div>
                        </div>
                    </NotAuthorized>
                    <Authorizing>
                        <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                        </div>
                    </Authorizing>
                </AuthorizeRouteView>
            </Found>
            <NotFound>
                <LayoutView Layout="@typeof(MainLayout)">
                    <div class="container mt-5">
                        <div class="alert alert-warning">
                            <h4>Pagina nu a fost găsită</h4>
                            <p>URL-ul cerut nu există.</p>
                            <a href="/" class="btn btn-primary">Înapoi la Acasă</a>
                        </div>
                    </div>
                </LayoutView>
            </NotFound>
        </Router>
    </CascadingAuthenticationState>

    <script src="_framework/blazor.server.js"></script>
</body>
</html>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    
    private void RedirectToLogin()
    {
        Navigation.NavigateTo("/auth/login");
    }

    private async Task OnNavigateAsync(Microsoft.AspNetCore.Components.Routing.NavigationContext context)
    {
        await Task.CompletedTask;
    }
}