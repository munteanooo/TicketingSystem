@inherits LayoutComponentBase
@using ClientUI.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider>
    <MudLayout>
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudText Typo="Typo.h6" Class="fw-bold">
                <i class="bi bi-ticket-detailed-fill me-2"></i>Ticketing System
            </MudText>
            <MudSpacer />
            <MudButton Color="Color.Inherit" Variant="Variant.Text" OnClick="@Logout" Class="text-white">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </MudButton>
        </MudAppBar>
        <MudMainContent Class="pt-4">
            <div class="container-fluid">
                @Body
            </div>
        </MudMainContent>
    </MudLayout>
</MudSnackbarProvider>

@code {
    [Inject] private JwtAuthStateProvider AuthProvider { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private async Task Logout()
    {
        await AuthProvider.LogoutAsync();
        Navigation.NavigateTo("/auth/login", true);
    }
}